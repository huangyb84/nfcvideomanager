{
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/v/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!_next/static|_next/image|favicon.ico).*)",
      "destination": "/public/$1"
    }
  ]
}
